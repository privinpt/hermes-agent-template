# ============================================================================
# Hermes Agent - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All configuration can also be done via the admin UI at http://your-ip:8080
# after deployment. This file is optional for pre-configuring credentials.
# ============================================================================

# ── Admin Authentication ──────────────────────────────────────────────────────
# Credentials for the admin dashboard at http://your-ip:8080
# If ADMIN_PASSWORD is not set, a random password will be generated and 
# printed in the container logs on first start.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Configure one or more LLM providers. Get free API keys from:
# - OpenRouter: https://openrouter.ai/keys (has free models)
# - DeepSeek: https://platform.deepseek.com
# - Others: see respective provider websites

# Recommended: OpenRouter (access to all models via one key)
OPENROUTER_API_KEY=
LLM_MODEL=google/gemma-3-1b-it:free

# Or: direct OpenAI
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Or: direct Anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-5

# Other providers
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# GLM_API_KEY=
# KIMI_API_KEY=
# MINIMAX_API_KEY=
# HF_TOKEN=
# NVIDIA_API_KEY=
# GEMINI_API_KEY=

# ── Tool Integration API Keys ─────────────────────────────────────────────────
# Optional: Enable additional capabilities

# Web search and scraping
EXA_API_KEY=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=
TAVILY_API_KEY=

# Image generation
FAL_KEY=

# Cross-session user modeling
HONCHO_API_KEY=

# GitHub (higher rate limits for code tools)
GITHUB_TOKEN=

# Browser automation
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Messaging Channel Tokens ──────────────────────────────────────────────────
# Configure messaging channels to interact with the agent

# Telegram (get from @BotFather)
# TELEGRAM_BOT_TOKEN=

# Discord (get from Discord Developer Portal)
# DISCORD_TOKEN=

# Slack (get from Slack App settings)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# WhatsApp (via Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Email (SMTP)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_FROM=

# ── Gateway Security ──────────────────────────────────────────────────────────
# Set to false and configure allowlists if you want to restrict access
GATEWAY_ALLOW_ALL_USERS=true

# ── Terminal Backend ──────────────────────────────────────────────────────────
# Options: local, docker, modal, ssh
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60
